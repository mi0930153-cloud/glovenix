{% comment %} Glovenix Reviews Section — USA Only, Meta Safe, 500+ Reviews {% endcomment %}

<style>
  .rv-wrap { font-family: 'PT Sans', sans-serif; max-width: 900px; margin: 0 auto; padding: 48px 20px 24px; }
  .rv-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 16px; }
  .rv-card { background: #fff; border: 0.5px solid #e4e4e4; border-radius: 14px; padding: 20px; position: relative; transition: box-shadow 0.2s; }
  .rv-card:hover { box-shadow: 0 4px 18px rgba(0,0,0,0.07); }
  .rv-card.featured { border: 2px solid #f2a0bc; background: #fffbfc; }
  .rv-avatar { width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 600; flex-shrink: 0; }
  .rv-stars { color: #f5a623; font-size: 15px; margin-bottom: 6px; letter-spacing: 1px; }
  .rv-title { font-size: 14px; font-weight: 700; color: #1a1a2e; margin-bottom: 6px; }
  .rv-body { font-size: 13px; color: #555; line-height: 1.75; margin: 0; }
  .rv-footer { font-size: 11px; color: #aaa; margin-top: 12px; padding-top: 10px; border-top: 0.5px solid #f0f0f0; }
  .rv-date { font-size: 11px; color: #bbb; margin-top: 5px; }
  .rv-badge-verified { background: #e8f7f0; color: #0F6E56; font-size: 10px; font-weight: 600; padding: 2px 8px; border-radius: 100px; display: inline-block; }
  .rv-badge-top { background: #fff0f5; color: #c2185b; font-size: 11px; font-weight: 600; padding: 3px 12px; border-radius: 100px; display: inline-block; margin-bottom: 12px; }
  .rv-name { font-size: 14px; font-weight: 700; color: #1a1a2e; }
  .rv-meta { font-size: 11px; color: #888; margin-top: 3px; }
  .rv-summary { display: flex; gap: 28px; align-items: center; background: #fff; border: 0.5px solid #e4e4e4; border-radius: 14px; padding: 24px; flex-wrap: wrap; margin-bottom: 20px; }
  .rv-big-rating { text-align: center; min-width: 110px; }
  .rv-big-num { font-size: 56px; font-weight: 700; line-height: 1; color: #1a1a2e; }
  .rv-big-stars { color: #f5a623; font-size: 24px; margin: 6px 0; letter-spacing: 2px; }
  .rv-bar-row { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
  .rv-bar-label { font-size: 12px; color: #888; width: 24px; text-align: right; flex-shrink: 0; }
  .rv-bar-track { flex: 1; height: 8px; background: #f3f3f3; border-radius: 4px; overflow: hidden; }
  .rv-bar-fill { height: 8px; background: #f5a623; border-radius: 4px; }
  .rv-bar-pct { font-size: 12px; color: #aaa; width: 34px; flex-shrink: 0; }
  .rv-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 24px; }
  .rv-tag { background: #f7f7f7; color: #666; font-size: 12px; padding: 6px 14px; border-radius: 100px; border: 0.5px solid #e8e8e8; }
  .rv-load-btn { width: 100%; padding: 14px; background: none; border: 0.5px solid #d0d0d0; border-radius: 12px; font-size: 14px; color: #555; cursor: pointer; margin-bottom: 16px; font-family: 'PT Sans', sans-serif; font-weight: 600; letter-spacing: 0.3px; transition: background 0.2s, color 0.2s; }
  .rv-load-btn:hover { background: #1a1a2e; color: #fff; }
  .rv-more-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  @media (max-width: 580px) {
    .rv-grid, .rv-more-grid { grid-template-columns: 1fr !important; }
    .rv-summary { flex-direction: column; }
    .rv-big-num { font-size: 44px; }
  }
</style>

