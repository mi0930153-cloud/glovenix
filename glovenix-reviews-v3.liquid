<style>
  .rv-wrap { font-family: 'PT Sans', sans-serif; max-width: 900px; margin: 0 auto; padding: 48px 20px 24px; }
  .rv-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 16px; }
  .rv-card { background: #ffffff; border: 1px solid #ebebeb; border-radius: 14px; padding: 18px; }
  .rv-card.featured { border: 2px solid #f2a0bc; background: #fffbfc; }
  .rv-avatar { width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 700; flex-shrink: 0; }
  .rv-stars { color: #f5a623; font-size: 14px; margin-bottom: 5px; letter-spacing: 1px; }
  .rv-title { font-size: 13px; font-weight: 700; color: #1a1a2e; margin-bottom: 5px; }
  .rv-body { font-size: 12px; color: #666; line-height: 1.65; margin: 0; }
  .rv-footer { font-size: 11px; color: #bbb; margin-top: 10px; padding-top: 8px; border-top: 1px solid #f5f5f5; }
  .rv-date { font-size: 11px; color: #ccc; margin-top: 4px; }
  .rv-badge-v { background: #e8f7f0; color: #0F6E56; font-size: 10px; font-weight: 600; padding: 2px 8px; border-radius: 100px; }
  .rv-badge-top { background: #fff0f5; color: #c2185b; font-size: 11px; font-weight: 600; padding: 3px 12px; border-radius: 100px; display: inline-block; margin-bottom: 10px; }
  .rv-name { font-size: 13px; font-weight: 700; color: #1a1a2e; }
  .rv-meta { font-size: 11px; color: #999; margin-top: 2px; }

  /* Summary Box */
  .rv-summary { display: flex; gap: 28px; align-items: center; background: #ffffff; border: 1px solid #ebebeb; border-radius: 14px; padding: 22px; flex-wrap: wrap; margin-bottom: 18px; }
  .rv-big-num { font-size: 54px; font-weight: 700; line-height: 1; color: #1a1a2e; }
  .rv-big-stars { color: #f5a623; font-size: 22px; margin: 5px 0; letter-spacing: 2px; }

  /* FIXED BARS */
  .rv-bar-row { display: flex; align-items: center; gap: 8px; margin-bottom: 7px; }
  .rv-bar-lbl { font-size: 12px; color: #888; width: 24px; text-align: right; flex-shrink: 0; }
  .rv-bar-track { flex: 1; height: 8px; background-color: #f0f0f0; border-radius: 4px; overflow: hidden; }
  .rv-bar-fill { height: 8px; background-color: #f5a623 !important; border-radius: 4px; display: block; }
  .rv-bar-pct { font-size: 12px; color: #999; width: 34px; flex-shrink: 0; }

  .rv-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 22px; }
  .rv-tag { background: #f7f7f7; color: #666; font-size: 12px; padding: 5px 13px; border-radius: 100px; border: 1px solid #ebebeb; }

  /* Load More Button */
  .rv-load-btn { width: 100%; padding: 14px; background: #ffffff; border: 1px solid #d0d0d0; border-radius: 12px; font-size: 14px; color: #555; cursor: pointer; margin-bottom: 16px; font-family: 'PT Sans', sans-serif; font-weight: 600; transition: all 0.2s; }
  .rv-load-btn:hover { background: #1a1a2e; color: #ffffff; border-color: #1a1a2e; }

  .rv-more-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  @media (max-width: 580px) {
    .rv-grid, .rv-more-grid { grid-template-columns: 1fr; }
    .rv-summary { flex-direction: column; }
  }
</style>

