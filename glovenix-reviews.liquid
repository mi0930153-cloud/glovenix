{% comment %} Glovenix Custom Reviews Section — Meta Safe, USA Only {% endcomment %}

<style>
  .glvx-reviews-wrap {
    max-width: 900px;
    margin: 60px auto;
    padding: 0 20px;
    font-family: 'PT Sans', sans-serif;
  }

  .glvx-reviews-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .glvx-reviews-header h2 {
    font-size: 28px;
    font-weight: 700;
    color: #1a1a2e;
    margin-bottom: 10px;
  }

  .glvx-rating-summary {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .glvx-big-score {
    font-size: 52px;
    font-weight: 700;
    color: #1a1a2e;
    line-height: 1;
  }

  .glvx-rating-right {
    text-align: left;
  }

  .glvx-stars-row {
    color: #f59e0b;
    font-size: 22px;
    letter-spacing: 2px;
  }

  .glvx-review-count {
    font-size: 13px;
    color: #888;
    margin-top: 2px;
  }

  .glvx-verified-badge {
    background: #f0fdf4;
    border: 1px solid #86efac;
    color: #16a34a;
    font-size: 11px;
    font-weight: 600;
    padding: 4px 12px;
    border-radius: 20px;
    letter-spacing: 0.5px;
  }

  .glvx-divider {
    height: 1px;
    background: #f0f0f0;
    margin: 30px 0;
  }

  .glvx-review-card {
    background: #ffffff;
    border: 1px solid #f0f0f0;
    border-radius: 16px;
    padding: 24px;
    margin-bottom: 16px;
    transition: box-shadow 0.2s ease;
    position: relative;
  }

  .glvx-review-card:hover {
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
  }

  .glvx-review-top {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    margin-bottom: 14px;
  }

  .glvx-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: linear-gradient(135deg, #f2a0bc, #db2777);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    font-weight: 700;
    color: #fff;
    flex-shrink: 0;
  }

  .glvx-reviewer-info {
    flex: 1;
  }

  .glvx-reviewer-name {
    font-size: 15px;
    font-weight: 700;
    color: #1a1a2e;
    margin-bottom: 2px;
  }

  .glvx-reviewer-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .glvx-reviewer-location {
    font-size: 12px;
    color: #999;
  }

  .glvx-verified-tag {
    font-size: 10px;
    font-weight: 600;
    color: #16a34a;
    background: #f0fdf4;
    border: 1px solid #86efac;
    padding: 2px 8px;
    border-radius: 10px;
  }

  .glvx-review-stars {
    color: #f59e0b;
    font-size: 14px;
    letter-spacing: 1px;
    margin-bottom: 4px;
  }

  .glvx-review-date {
    font-size: 11px;
    color: #bbb;
  }

  .glvx-review-title {
    font-size: 15px;
    font-weight: 700;
    color: #1a1a2e;
    margin-bottom: 8px;
  }

  .glvx-review-body {
    font-size: 14px;
    color: #555;
    line-height: 1.7;
  }

  .glvx-review-photo {
    width: 70px;
    height: 70px;
    border-radius: 10px;
    object-fit: cover;
    margin-top: 12px;
    border: 1px solid #f0f0f0;
  }

  .glvx-helpful-tag {
    position: absolute;
    top: 20px;
    right: 20px;
    font-size: 10px;
    color: #bbb;
  }

  .glvx-hidden-reviews {
    display: none;
  }

  .glvx-load-more-wrap {
    text-align: center;
    margin-top: 24px;
  }

  .glvx-load-more-btn {
    background: #1a1a2e;
    color: #ffffff;
    border: none;
    padding: 14px 40px;
    border-radius: 50px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    letter-spacing: 0.5px;
    font-family: 'PT Sans', sans-serif;
    transition: background 0.2s, transform 0.15s;
  }

  .glvx-load-more-btn:hover {
    background: #f2a0bc;
    color: #1a1a2e;
    transform: scale(1.02);
  }

  .glvx-load-more-sub {
    font-size: 12px;
    color: #bbb;
    margin-top: 10px;
  }
</style>

<div class="glvx-reviews-wrap">

  <!-- Header -->
  <div class="glvx-reviews-header">
    <h2>What Our Customers Are Saying</h2>
    <div class="glvx-rating-summary">
      <div class="glvx-big-score">4.8</div>
      <div class="glvx-rating-right">
        <div class="glvx-stars-row">★★★★★</div>
        <div class="glvx-review-count">Based on 67 reviews</div>
      </div>
      <div class="glvx-verified-badge">✓ Verified USA Customers</div>
    </div>
  </div>

  <div class="glvx-divider"></div>

  <!-- Review 1 -->
  <div class="glvx-review-card">
    <span class="glvx-helpful-tag">✓ Verified Purchase</span>
