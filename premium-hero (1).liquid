{% doc %}
  @prompt Premium Hero Section with working countdown timer including Days
{% enddoc %}

{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}

.ai-premium-hero-{{ ai_gen_id }} {
  display: block;
  width: 100%;
}

.ai-hero-container-{{ ai_gen_id }} {
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: {{ block.settings.min_height }}px;
  padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
  gap: 40px;
  position: relative;
  overflow: hidden;
  background-color: {{ block.settings.background_color }};
  width: {{ block.settings.desktop_width_percent }}%;
  max-width: 100%;
  margin: 0 auto;
}

.ai-hero-container-{{ ai_gen_id }}::before {
  content: "";
  position: absolute;
  width: 500px;
  height: 500px;
  background: radial-gradient(circle, {{ block.settings.glow_color }}33, {{ block.settings.background_color }});
  left: -150px;
  top: 50px;
  z-index: 0;
  opacity: {{ block.settings.glow_opacity }};
}

.ai-hero-left-{{ ai_gen_id }} {
  flex: 1;
  z-index: 2;
}

.ai-badge-{{ ai_gen_id }} {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 6px 14px;
  border: 1px solid {{ block.settings.badge_border_color }};
  color: {{ block.settings.badge_text_color }};
  border-radius: 50px;
  font-size: 12px;
  margin-bottom: 20px;
}

.ai-dot-{{ ai_gen_id }} {
  width: 8px;
  height: 8px;
  background: {{ block.settings.badge_dot_color }};
  border-radius: 50%;
  animation: ai-pulse-{{ ai_gen_id }} 1.5s infinite;
}

@keyframes ai-pulse-{{ ai_gen_id }} {
  0% { opacity: 1; }
  50% { opacity: 0.3; }
  100% { opacity: 1; }
}

.ai-headline-{{ ai_gen_id }} {
  font-size: {{ block.settings.heading_size }}px;
  font-weight: {{ block.settings.heading_weight }};
  margin: 0;
  line-height: 1.1;
  color: {{ block.settings.heading_color }};
  letter-spacing: {{ block.settings.heading_letter_spacing }}px;
}

.ai-gradient-text-{{ ai_gen_id }} {
  background: linear-gradient(90deg, {{ block.settings.gradient_color_1 }}, {{ block.settings.gradient_color_2 }});
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.ai-subtext-{{ ai_gen_id }} {
  color: {{ block.settings.subtext_color }};
  margin-top: 10px;
  font-size: {{ block.settings.subtext_size }}px;
  line-height: 1.6;
}

.ai-price-box-{{ ai_gen_id }} {
  margin-top: 20px;
}

.ai-old-price-{{ ai_gen_id }} {
  text-decoration: line-through;
  color: {{ block.settings.old_price_color }};
  font-size: {{ block.settings.old_price_size }}px;
}

.ai-new-price-{{ ai_gen_id }} {
  font-size: {{ block.settings.new_price_size }}px;
  font-weight: {{ block.settings.new_price_weight }};
  color: {{ block.settings.new_price_color }};
}

.ai-discount-{{ ai_gen_id }} {
  display: inline-block;
  padding: 4px 10px;
  background: linear-gradient(90deg, {{ block.settings.gradient_color_1 }}, {{ block.settings.gradient_color_2 }});
  border-radius: 20px;
  font-size: 12px;
  margin-left: 10px;
  color: {{ block.settings.discount_text_color }};
}

.ai-timer-{{ ai_gen_id }} {
  margin-top: 20px;
}

.ai-timer-label-{{ ai_gen_id }} {
  font-size: 12px;
  color: {{ block.settings.timer_label_color }};
}

.ai-timer-box-{{ ai_gen_id }} {
  display: flex;
  gap: 10px;
  margin-top: 10px;
  flex-wrap: wrap;
}

.ai-time-{{ ai_gen_id }} {
  background: {{ block.settings.timer_bg_color }};
  padding: 10px 14px;
  border-radius: 10px;
  text-align: center;
  min-width: 60px;
}

.ai-time-{{ ai_gen_id }} span {
  font-size: 18px;
  display: block;
  color: {{ block.settings.timer_number_color }};
  font-variant-numeric: tabular-nums;
}

.ai-time-{{ ai_gen_id }} small {
  color: {{ block.settings.timer_text_color }};
  font-size: 11px;
}

.ai-buttons-{{ ai_gen_id }} {
  display: flex;
  gap: 10px;
  margin-top: 25px;
  flex-wrap: wrap;
}

.ai-btn-{{ ai_gen_id }} {
  padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
  border-radius: 50px;
  font-weight: {{ block.settings.button_font_weight }};
  font-size: {{ block.settings.button_font_size }}px;
  cursor: pointer;
  transition: 0.3s;
  text-decoration: none;
  display: inline-block;
}

.ai-primary-{{ ai_gen_id }} {
  background: linear-gradient(90deg, {{ block.settings.gradient_color_1 }}, {{ block.settings.gradient_color_2 }});
  border: none;
  color: {{ block.settings.primary_button_text_color }};
}

.ai-primary-{{ ai_gen_id }}:hover {
  transform: scale(1.05);
  opacity: 0.9;
}

.ai-ghost-{{ ai_gen_id }} {
  border: 1px solid {{ block.settings.secondary_button_border_color }};
  background: transparent;
  color: {{ block.settings.secondary_button_text_color }};
}

.ai-ghost-{{ ai_gen_id }}:hover {
  opacity: 0.7;
}

.ai-trust-{{ ai_gen_id }} {
  font-size: 12px;
  color: {{ block.settings.trust_text_color }};
  margin-top: 10px;
  line-height: 1.8;
}

.ai-hero-right-{{ ai_gen_id }} {
  flex: 1;
  z-index: 2;
  position: relative;
}

.ai-frame-{{ ai_gen_id }} {
  border: 2px dashed {{ block.settings.image_border_color }};
  border-radius: 20px;
  overflow: hidden;
  position: relative;
  aspect-ratio: 4/5;
  background: {{ block.settings.image_frame_bg }};
  display: flex;
  justify-content: center;
  align-items: center;
  text-align: center;
}

.ai-frame-{{ ai_gen_id }} img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.ai-upload-placeholder-{{ ai_gen_id }} {
  color: {{ block.settings.placeholder_text_color }};
}

.ai-upload-placeholder-{{ ai_gen_id }} svg {
  width: 100%;
  height: 100%;
  max-width: 300px;
  max-height: 300px;
}

.ai-upload-icon-{{ ai_gen_id }} {
  width: 40px;
  height: 40px;
  background: {{ block.settings.gradient_color_1 }};
  border-radius: 50%;
  margin: 0 auto 10px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ai-card-{{ ai_gen_id }} {
  position: absolute;
  background: {{ block.settings.floating_card_bg }};
  padding: 10px 14px;
  border-radius: 10px;
  font-size: 12px;
  color: {{ block.settings.floating_card_text }};
}

.ai-top-right-{{ ai_gen_id }} {
  top: 10px;
  right: 10px;
}

.ai-bottom-right-{{ ai_gen_id }} {
  bottom: 10px;
  right: 10px;
}

@media (max-width: 768px) {
  .ai-hero-container-{{ ai_gen_id }} {
    flex-direction: column;
    padding: 30px;
  }

  .ai-hero-right-{{ ai_gen_id }} {
    order: 1;
    width: 100%;
  }

  .ai-hero-left-{{ ai_gen_id }} {
    order: 2;
  }

  .ai-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size | times: 0.7 }}px;
  }

  .ai-timer-box-{{ ai_gen_id }} {
    gap: 6px;
  }

  .ai-time-{{ ai_gen_id }} {
    min-width: 52px;
    padding: 8px 10px;
  }
}

{% endstyle %}

<ai-premium-hero-{{ ai_gen_id }} class="ai-premium-hero-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-container-{{ ai_gen_id }}">

    <div class="ai-hero-left-{{ ai_gen_id }}">

      {% if block.settings.show_badge %}
        <div class="ai-badge-{{ ai_gen_id }}">
          <div class="ai-dot-{{ ai_gen_id }}"></div>
          {{ block.settings.badge_text }}
        </div>
      {% endif %}

      <h1 class="ai-headline-{{ ai_gen_id }}">
        {{ block.settings.heading_part_1 }}
        {% if block.settings.heading_part_2 != blank %}
          <span class="ai-gradient-text-{{ ai_gen_id }}">{{ block.settings.heading_part_2 }}</span>
        {% endif %}
        {{ block.settings.heading_part_3 }}
      </h1>

      {% if block.settings.subtext != blank %}
        <div class="ai-subtext-{{ ai_gen_id }}">
          {{ block.settings.subtext }}
        </div>
      {% endif %}

      {% if block.settings.show_pricing %}
        <div class="ai-price-box-{{ ai_gen_id }}">
          {% if block.settings.old_price != blank %}
            <div class="ai-old-price-{{ ai_gen_id }}">{{ block.settings.old_price }}</div>
          {% endif %}
          <div class="ai-new-price-{{ ai_gen_id }}">
            {{ block.settings.new_price }}
            {% if block.settings.discount_badge != blank %}
              <span class="ai-discount-{{ ai_gen_id }}">{{ block.settings.discount_badge }}</span>
            {% endif %}
          </div>
        </div>
      {% endif %}

      {% if block.settings.show_timer %}
        <div class="ai-timer-{{ ai_gen_id }}">
          <small class="ai-timer-label-{{ ai_gen_id }}">{{ block.settings.timer_label }}</small>
          <div class="ai-timer-box-{{ ai_gen_id }}">

            <!-- ✅ DAYS BOX - FIXED -->
            <div class="ai-time-{{ ai_gen_id }}">
              <span data-timer-days>00</span>
              <small>Days</small>
            </div>

            <div class="ai-time-{{ ai_gen_id }}">
              <span data-timer-hours>00</span>
              <small>{{ block.settings.hours_label }}</small>
            </div>

            <div class="ai-time-{{ ai_gen_id }}">
              <span data-timer-minutes>00</span>
              <small>{{ block.settings.minutes_label }}</small>
            </div>

            <div class="ai-time-{{ ai_gen_id }}">
              <span data-timer-seconds>00</span>
              <small>{{ block.settings.seconds_label }}</small>
            </div>

          </div>
        </div>
      {% endif %}

      <div class="ai-buttons-{{ ai_gen_id }}">
        {% if block.settings.primary_button_text != blank %}
          <a href="{{ block.settings.primary_button_link }}" class="ai-btn-{{ ai_gen_id }} ai-primary-{{ ai_gen_id }}">
            {{ block.settings.primary_button_text }}
          </a>
        {% endif %}
        {% if block.settings.secondary_button_text != blank %}
          <a href="{{ block.settings.secondary_button_link }}" class="ai-btn-{{ ai_gen_id }} ai-ghost-{{ ai_gen_id }}">
            {{ block.settings.secondary_button_text }}
          </a>
        {% endif %}
      </div>

      {% if block.settings.trust_text != blank %}
        <div class="ai-trust-{{ ai_gen_id }}">
          {{ block.settings.trust_text }}
        </div>
      {% endif %}

    </div>

    <div class="ai-hero-right-{{ ai_gen_id }}">
      <div class="ai-frame-{{ ai_gen_id }}">

        {% if block.settings.hero_image %}
          <img
            src="{{ block.settings.hero_image | image_url: width: 1000 }}"
            alt="{{ block.settings.hero_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.hero_image.width }}"
            height="{{ block.settings.hero_image.height }}"
          >
        {% else %}
          <div class="ai-upload-placeholder-{{ ai_gen_id }}">
            {{ 'hero-apparel-1' | placeholder_svg_tag }}
          </div>
        {% endif %}

        {% if block.settings.floating_card_1_text != blank %}
          <div class="ai-card-{{ ai_gen_id }} ai-top-right-{{ ai_gen_id }}">
            {{ block.settings.floating_card_1_text }}
          </div>
        {% endif %}

        {% if block.settings.floating_card_2_text != blank %}
          <div class="ai-card-{{ ai_gen_id }} ai-bottom-right-{{ ai_gen_id }}">
            {{ block.settings.floating_card_2_text }}
          </div>
        {% endif %}

      </div>
    </div>

  </div>
</ai-premium-hero-{{ ai_gen_id }}>

<script>
(function() {

  class AiPremiumHero{{ ai_gen_id }} extends HTMLElement {

    constructor() {
      super();
      this.timerEnabled = {{ block.settings.show_timer | json }};
      this.endDate = null;
      this.timerInterval = null;
    }

    connectedCallback() {
      if (this.timerEnabled) {
        this.initTimer();
      }
    }

    initTimer() {
      const endDateStr = '{{ block.settings.timer_end_date }}';
      const endTimeStr = '{{ block.settings.timer_end_time }}';

      if (!endDateStr || !endTimeStr) {
        return;
      }

      this.endDate = new Date(endDateStr + 'T' + endTimeStr);

      if (isNaN(this.endDate.getTime())) {
        return;
      }

      this.updateTimer();
      this.timerInterval = setInterval(() => this.updateTimer(), 1000);
    }

    updateTimer() {
      const now = new Date().getTime();
      const distance = this.endDate.getTime() - now;

      if (distance < 0) {
        clearInterval(this.timerInterval);
        this.setTimerValues(0, 0, 0, 0);
        return;
      }

      /* ✅ FIXED - Days calculation added */
      const days    = Math.floor(distance / (1000 * 60 * 60 * 24));
      const hours   = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
      const seconds = Math.floor((distance % (1000 * 60)) / 1000);

      this.setTimerValues(days, hours, minutes, seconds);
    }

    /* ✅ FIXED - Days parameter added */
    setTimerValues(days, hours, minutes, seconds) {
      const daysEl    = this.querySelector('[data-timer-days]');
      const hoursEl   = this.querySelector('[data-timer-hours]');
      const minutesEl = this.querySelector('[data-timer-minutes]');
      const secondsEl = this.querySelector('[data-timer-seconds]');

      if (daysEl)    daysEl.textContent    = String(days).padStart(2, '0');
      if (hoursEl)   hoursEl.textContent   = String(hours).padStart(2, '0');
      if (minutesEl) minutesEl.textContent = String(minutes).padStart(2, '0');
      if (secondsEl) secondsEl.textContent = String(seconds).padStart(2, '0');
    }

    disconnectedCallback() {
      if (this.timerInterval) {
        clearInterval(this.timerInterval);
      }
    }
  }

  customElements.define('ai-premium-hero-{{ ai_gen_id }}', AiPremiumHero{{ ai_gen_id }});

})();
</script>

